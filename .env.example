# =============================================================================
# GAME TIME GIFT — Environment Variable Reference
# =============================================================================
# This file is committed to source control. It documents every variable
# the application requires. It contains NO real secrets.
#
# USAGE:
#   Copy this file to .env.local in each app that needs it:
#     cp .env.example apps/storefront/.env.local
#     cp .env.example apps/admin/.env.local
#     cp .env.example apps/consultant/.env.local
#
#   Then replace placeholder values with real credentials.
#   .env.local is never committed (see .gitignore).
#
# VITE_ PREFIX RULE:
#   Variables prefixed with VITE_ are injected into the browser bundle.
#   Variables WITHOUT the VITE_ prefix are server/Edge Function only.
#   Never put a secret key under VITE_ — it will be publicly visible.
#
# EDGE FUNCTION SECRETS:
#   Server-only variables consumed by Supabase Edge Functions are set via:
#     supabase secrets set VAR_NAME=value
#   They are NOT read from .env.local — .env.local is for Vite apps only.
#   The variables below without VITE_ prefix are documented here for reference
#   and must be set as Supabase project secrets before deploying functions.
# =============================================================================


# ─── Supabase ────────────────────────────────────────────────────────────────
# Project URL from: Supabase dashboard > Settings > API
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Anon key — safe for browser. Subject to Row Level Security (RLS).
# From: Supabase dashboard > Settings > API > Project API Keys
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.REPLACE_ME

# Service role key — NEVER prefix with VITE_. NEVER expose to browser.
# Bypasses all RLS. Used only inside Supabase Edge Functions (Deno runtime).
# Auto-injected by the Supabase runtime; set via `supabase secrets set` for CI.
# From: Supabase dashboard > Settings > API > Project API Keys
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.REPLACE_ME


# ─── Stripe ─────────────────────────────────────────────────────────────────
# Publishable key — safe for browser.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Secret key — NEVER prefix with VITE_. Edge Function only.
# Set via: supabase secrets set STRIPE_SECRET_KEY=sk_live_...
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# Stripe webhook signing secret — used to verify Stripe event payloads.
# Obtain from: Stripe dashboard > Developers > Webhooks > signing secret.
# Set via: supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME


# ─── Edge Function: System Service Account ───────────────────────────────────
# The auth.users.id of the GTG system service account.
# Used as performed_by on records created by automated processes (Stripe webhook,
# fraud auto-lock, scheduled jobs) where no human user initiated the action.
# Create a dedicated service account user in Supabase Auth and paste its UUID here.
# Set via: supabase secrets set GTG_SERVICE_ACCOUNT_ID=<uuid>
GTG_SERVICE_ACCOUNT_ID=00000000-0000-0000-0000-000000000000


# ─── Edge Function: Storefront URL ───────────────────────────────────────────
# Public base URL of the storefront application.
# Used by get-referral-link to construct consultant referral URLs:
#   ${STOREFRONT_URL}/shop?ref=<referral_code>
# No trailing slash. Must match the production storefront domain exactly.
# Set via: supabase secrets set STOREFRONT_URL=https://gametimegift.com
STOREFRONT_URL=https://gametimegift.com

# Comma-separated allowlist of web origins permitted to call public edge
# functions and to be used as checkout redirect URL origins.
# Keep STOREFRONT_URL included here if multiple frontend origins exist.
# Set via: supabase secrets set ALLOWED_WEB_ORIGINS=https://gametimegift.com,https://staging.gametimegift.com
ALLOWED_WEB_ORIGINS=https://gametimegift.com


# ─── Application Identity ────────────────────────────────────────────────────
VITE_APP_NAME=Game Time Gift
# Values: development | staging | production
VITE_APP_ENV=development


# ─── Fraud Authority ─────────────────────────────────────────────────────────
# Comma-separated list of user roles permitted to issue unit lock/unlock.
# These map to roles defined in Supabase Auth custom claims.
# Do not add roles here that do not exist in the auth schema.
VITE_FRAUD_AUTHORITY_ROLES=admin,legal


# ─── License Configuration ───────────────────────────────────────────────────
# Flags that control which license holders are active for royalty reporting.
# Both may be true simultaneously.
VITE_LICENSE_CLC_ACTIVE=true
VITE_LICENSE_ARMY_ACTIVE=true

# Royalty rate per license holder (decimal, e.g. 0.14 = 14%).
# These are read-only display values. Authoritative rates live in the database.
VITE_ROYALTY_RATE_CLC=0.14
VITE_ROYALTY_RATE_ARMY=0.00


# ─── Hologram Verification ───────────────────────────────────────────────────
# Base URL for the public hologram verification endpoint.
# The storefront uses this to construct the public verify link per unit.
VITE_HOLOGRAM_VERIFY_BASE_URL=https://verify.gametimegift.com
