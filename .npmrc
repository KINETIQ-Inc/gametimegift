# pnpm workspace configuration
# Enforces workspace: protocol for all internal packages
link-workspace-packages=true

# Prevents installing packages not listed in package.json
save-exact=false

# Hoist only specific packages to root node_modules (avoids phantom deps)
# All other resolution stays in package-specific node_modules
shamefully-hoist=false
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=*typescript*

# Fail if node version doesn't match engines field
engine-strict=true
